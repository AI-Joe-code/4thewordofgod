# LM Studio (OpenAI-compatible) endpoint serving the Qwen translation model.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Base URL — must include the /v1 suffix for the OpenAI-compatible API.
LMSTUDIO_BASE_URL=http://100.73.250.103:1234/v1

# LM Studio API key (sent as `Authorization: Bearer <key>`).
LMSTUDIO_API_KEY=lm-...

# Model identifier exactly as served by LM Studio (see GET /v1/models).
MODEL_ID=qwen/qwen3.5-35b-a3b
