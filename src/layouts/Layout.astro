---
import Sidebar from '../components/Sidebar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { ClientRouter } from 'astro:transitions';
import { SITE_URL, DEFAULT_LANG, DEFAULT_OG_IMAGE, HAS_OG_IMAGE } from '../lib/site';
import { getOgLocale } from '../lib/languages';

// Self-hosted Latin display fonts: same-origin, immutable-cached, and
// non-render-blocking (bundled by Vite), replacing the render-blocking Google
// Fonts stylesheet. These cover Latin only; non-Latin scripts fall back to the
// per-script system stacks defined in --font-display / --font-body below.
import '@fontsource/cinzel/latin-400.css';
import '@fontsource/cinzel/latin-700.css';
import '@fontsource/lato/latin-400.css';
import '@fontsource/lato/latin-700.css';

// Preload the two above-the-fold faces (Cinzel heading + Lato body). Lighthouse
// showed fonts on the critical path; ?url resolves to the same hashed woff2 the
// @font-face rules use (verified — no extra asset), so they just start earlier.
import cinzel700 from '@fontsource/cinzel/files/cinzel-latin-700-normal.woff2?url';
import lato400 from '@fontsource/lato/files/lato-latin-400-normal.woff2?url';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  keywords?: string[];
  structuredData?: object[];
  dir?: 'LTR' | 'RTL';
  currentLang?: string;
  chapters?: { chapter_number: string | number; original_title: string | null }[];
  currentBook?: string;
  currentChapter?: string | number;
  firstChapters?: Record<string, string>;
  /** Available language codes for hreflang alternates (>1 to render them). */
  langCodes?: string[];
  ogType?: 'website' | 'article';
  ogImage?: string;
  robots?: string;
}

const {
  title,
  description = 'A Bible commentary platform.',
  ogTitle,
  ogDescription,
  structuredData = [],
  dir = 'LTR',
  currentLang,
  chapters = [],
  currentBook,
  currentChapter,
  firstChapters = {},
  langCodes = [],
  ogType = 'website',
  ogImage = DEFAULT_OG_IMAGE,
  robots = 'index, follow',
} = Astro.props;

// Force the production origin (the SSR request host may be a preview/workers.dev
// domain) and drop any query string so every page self-canonicals cleanly.
// The root `/` serves the default-language home, so canonical it (and derive
// hreflang) as `/{DEFAULT_LANG}` — the bare domain consolidates with the
// language home instead of duplicating it.
const path = Astro.url.pathname === '/' ? `/${DEFAULT_LANG}` : Astro.url.pathname;
const canonical = new URL(path, SITE_URL).href;

// hreflang alternates: every route is /{lang}/..., so swap the leading lang
// segment for each available language. x-default points at the default lang.
const segs = path.split('/'); // e.g. ['', 'en', 'daniel', '00']
const hasLangSeg = segs.length > 1 && segs[1].length > 0;
const alternates =
  langCodes.length > 1 && hasLangSeg
    ? langCodes.map((code) => {
        const s = [...segs];
        s[1] = code;
        return { code, href: new URL(s.join('/'), SITE_URL).href };
      })
    : [];
const xDefaultHref =
  alternates.length > 0
    ? new URL([...segs.slice(0, 1), DEFAULT_LANG, ...segs.slice(2)].join('/'), SITE_URL).href
    : null;

const ogImageUrl = HAS_OG_IMAGE ? ogImage : null;
---

<!doctype html>
<html lang={currentLang || 'en'} dir={dir === 'RTL' ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" href={cinzel700} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={lato400} as="font" type="font/woff2" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="canonical" href={canonical} />
    <meta name="robots" content={robots} />

    <!-- hreflang alternates for the language variants of this URL -->
    {alternates.map((a) => <link rel="alternate" hreflang={a.code} href={a.href} />)}
    {xDefaultHref && <link rel="alternate" hreflang="x-default" href={xDefaultHref} />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="4thewordofgod" />
    <meta property="og:locale" content={getOgLocale(currentLang || DEFAULT_LANG)} />
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || description} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {/* dimensions match the 1200x630 default social image */}
    {ogImageUrl && <meta property="og:image:width" content="1200" />}
    {ogImageUrl && <meta property="og:image:height" content="630" />}
    {ogImageUrl && <meta property="og:image:alt" content={ogTitle || title} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={ogTitle || title} />
    <meta name="twitter:description" content={ogDescription || description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {ogImageUrl && <meta name="twitter:image:alt" content={ogTitle || title} />}

    {
      structuredData.length > 0 && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }
    <ClientRouter />
    <script is:inline>
      // Apply the saved/system theme before first paint AND before every
      // View Transitions swap. The swap resets <html>'s attributes to the
      // freshly-fetched (theme-less) markup, so without the after-swap
      // re-apply the page would flash the light theme for one frame.
      (function () {
        const applyTheme = function () {
          const theme =
            localStorage.getItem('theme') ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        };
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="app-container">
      <button
        class="nav-hamburger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="primary-sidebar"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      <div class="nav-overlay" aria-hidden="true"></div>
      <Sidebar
        chapters={chapters}
        currentBook={currentBook}
        currentChapter={currentChapter}
        currentLang={currentLang}
        firstChapters={firstChapters}
      />
      <div class="top-controls" transition:persist>
        <ThemeToggle />
      </div>
      <main class="main-content" id="main-content">
        <slot />
      </main>
    </div>
    <script>
      // Mobile navigation drawer toggle.
      // Document/window-level listeners are registered once; element-level
      // listeners are re-bound on every astro:page-load (ViewTransitions swaps the DOM).
      const root = document.documentElement;
      const closeNav = () => {
        root.removeAttribute('data-nav-open');
        document.querySelector('.nav-hamburger')?.setAttribute('aria-expanded', 'false');
      };
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeNav();
      });

      function initMobileNav() {
        const hamburger = document.querySelector('.nav-hamburger');
        const overlay = document.querySelector('.nav-overlay');
        const sidebar = document.querySelector('.sidebar');

        hamburger?.addEventListener('click', () => {
          if (root.hasAttribute('data-nav-open')) {
            closeNav();
          } else {
            root.setAttribute('data-nav-open', '');
            hamburger.setAttribute('aria-expanded', 'true');
          }
        });
        overlay?.addEventListener('click', closeNav);
        // Close the drawer when any link inside it is tapped.
        sidebar?.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).closest('a')) closeNav();
        });
        closeNav(); // ensure a known (closed) state on every page load
      }
      document.addEventListener('astro:page-load', initMobileNav);
    </script>
  </body>
</html>
<style is:global>
  :root {
    --theme-bg: #f7f5f0; /* Alabaster - Warm off-white, less yellow */
    --theme-text: #1a1510; /* Ink Black/Brown */
    --theme-accent: #8b6c30; /* Darker Gold/Bronze */
    --theme-border: #d4c4a0; /* Darker Parchment */
    --theme-surface: #eaddcf; /* Lighter Parchment for cards */

    --theme-surface-highlight: rgba(0, 0, 0, 0.05); /* Subtle darkening for footers */
    --theme-hover-bg: rgba(139, 108, 48, 0.1); /* Darker Gold tint */
    --theme-active-bg: rgba(139, 108, 48, 0.2); /* Stronger Gold tint */

    /* Font sizes */
    --font-size-base: 16px;
    --font-size-lg: 1.25rem;
    --font-size-xl: 1.5rem;

    /* Font stacks. Cinzel/Lato are self-hosted Latin-only; the trailing
       families cover the fallback while fonts load and, for non-Latin scripts
       (ar/he/fa/ur/CJK/Indic/…), hand off to the reader's native system fonts. */
    --font-display: 'Cinzel', Georgia, Cambria, 'Times New Roman', 'Noto Serif', serif;
    --font-body:
      'Lato', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans',
      sans-serif;
  }

  /* Dark Mode Override */
  [data-theme='dark'] {
    --theme-bg: #1a1510; /* Dark Leather/Wood */
    --theme-text: #f7f5f0; /* Parchment White */
    --theme-accent: #b48c50; /* Gold */
    --theme-border: #3d3020; /* Darker Wood */
    --theme-surface: #251f18; /* Slightly lighter background for cards */

    --theme-surface-highlight: rgba(0, 0, 0, 0.2); /* Darker darkening for footers */
    --theme-hover-bg: rgba(180, 140, 80, 0.1); /* Lighter Gold tint */
    --theme-active-bg: rgba(180, 140, 80, 0.2); /* Stronger Gold tint */
  }

  html {
    font-family: var(--font-body);
    background: var(--theme-bg);
    color: var(--theme-text);
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }
  body {
    margin: 0;
    padding: 0;
  }

  /* Keyboard a11y: visible focus ring + skip link to the main content. */
  :focus-visible {
    outline: 2px solid var(--theme-accent);
    outline-offset: 2px;
  }
  .skip-link {
    position: absolute;
    left: 0.5rem;
    top: -3rem;
    z-index: 2000;
    padding: 0.5rem 1rem;
    background: var(--theme-surface);
    color: var(--theme-text);
    border: 1px solid var(--theme-border);
    border-radius: 6px;
    text-decoration: none;
    transition: top 0.2s ease;
  }
  .skip-link:focus {
    top: 0.5rem;
  }
  .app-container {
    display: flex;
    min-height: 100vh;
  }
  .main-content {
    flex-grow: 1;
    margin-left: 280px; /* Width of sidebar */
    padding: 2rem;
    background: var(--theme-bg);
    transition: background-color 0.3s ease;
  }
  .top-controls {
    position: fixed;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 1000;
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  /* Mobile navigation: hamburger + overlay are desktop-hidden by default. */
  .nav-hamburger {
    display: none;
  }
  .nav-overlay {
    display: none;
  }

  @media (max-width: 768px) {
    .main-content {
      margin-left: 0;
      padding: 1.5rem 1rem;
      padding-top: 4.5rem; /* clear the fixed hamburger button */
    }

    .nav-hamburger {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      top: 1rem;
      left: 1rem;
      z-index: 1200;
      width: 44px;
      height: 44px;
      padding: 0;
      border: 1px solid var(--theme-border);
      border-radius: 8px;
      background: var(--theme-surface);
      color: var(--theme-text);
      cursor: pointer;
    }
    .nav-hamburger svg {
      width: 24px;
      height: 24px;
    }

    .nav-overlay {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 1050;
      background: rgba(0, 0, 0, 0.5);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }
    [data-nav-open] .nav-overlay {
      opacity: 1;
      pointer-events: auto;
    }
    /* Lock background scroll while the drawer is open. */
    [data-nav-open] {
      overflow: hidden;
    }
  }
  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }

  h1,
  .page-title {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    text-align: center;
    margin-bottom: 1em;
    font-family: var(--font-display);
    color: var(--theme-text);
  }

  /* Placed after the base rule so it wins on mobile (equal specificity). */
  @media (max-width: 768px) {
    h1,
    .page-title {
      font-size: 2rem;
      overflow-wrap: break-word;
    }
  }
</style>
