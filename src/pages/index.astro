---
// Root entry point. Serves the default-language (English / x-default) homepage
// directly — no Accept-Language redirect. Avoiding the redirect removes a
// round-trip (faster), and Google prefers no auto-redirect by language. The
// content is rendered by rewriting to /{DEFAULT_LANG}; the canonical points at
// /{DEFAULT_LANG} (Layout maps the root path) so `/` and `/en` consolidate
// instead of competing as duplicate content.
export const prerender = false;

import { DEFAULT_LANG } from '../lib/site';

return Astro.rewrite(`/${DEFAULT_LANG}`);
---
