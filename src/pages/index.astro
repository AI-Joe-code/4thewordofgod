---
// Root entry point: detect the visitor's language from the Accept-Language
// header and redirect to the matching per-language homepage (/{lang}).
// Falls back to English. Canonical homepages live at /[lang]/.
export const prerender = false;

import { env } from 'cloudflare:workers';

const DEFAULT_LANG = 'en';

let available: string[] = [DEFAULT_LANG];
try {
  const raw = await env.MANIFEST?.get('manifest:languages');
  if (raw) available = JSON.parse(raw);
} catch {
  // fall back to default
}

// Parse Accept-Language into base codes in preference order (highest q first).
const accept = Astro.request.headers.get('accept-language') || '';
const preferred = accept
  .split(',')
  .map((part) => {
    const [tag, q] = part.trim().split(';q=');
    return { code: tag.split('-')[0].toLowerCase(), q: q ? parseFloat(q) : 1 };
  })
  .filter((p) => p.code)
  .sort((a, b) => b.q - a.q)
  .map((p) => p.code);

const chosen = preferred.find((code) => available.includes(code)) || DEFAULT_LANG;

return Astro.redirect(`/${chosen}`, 302);
---
