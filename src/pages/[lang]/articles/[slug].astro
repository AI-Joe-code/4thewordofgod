---
// Rendered on-demand from R2 (public-content/{lang}/articles/{slug}.json), like
// chapters — no longer prerendered from content-source. Navigation comes from
// the per-language KV manifest.
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import FloatingControls from '../../../components/FloatingControls.astro';
import FAQ from '../../../components/FAQ.astro';
import { getLanguageDirection, getAvailableLanguages } from '../../../lib/languages';
import type { CommentaryData } from '../../../lib/content';
import { AUDIO_BASE, SITE_URL } from '../../../lib/site';
import { normalizeStructuredData } from '../../../lib/seo';
import { env } from 'cloudflare:workers';

const { lang, slug } = Astro.params;
if (!lang || !slug) {
  return Astro.rewrite('/404');
}

if (!env.R2) {
  return new Response('R2 binding unavailable', { status: 500 });
}

const obj = await env.R2.get(`public-content/${lang}/articles/${slug}.json`);
if (!obj) {
  return Astro.rewrite('/404');
}
const data = (await obj.json()) as CommentaryData;

// Navigation: sidebar first-chapters and the sibling-article list (for
// prev/next) both come from the per-language manifest in KV.
const firstChaptersMap: Record<string, string> = {};
let articles: { slug: string; date?: string | null }[] = [];

const manifestRaw = await env.MANIFEST?.get(`manifest:${lang}`);
if (manifestRaw) {
  const manifest = JSON.parse(manifestRaw) as {
    books: Record<string, { chapters: { n: string }[] }>;
    articles?: { slug: string; date?: string | null }[];
  };
  for (const bk in manifest.books) {
    firstChaptersMap[bk] = manifest.books[bk].chapters[0]?.n ?? '01';
  }
  articles = manifest.articles ?? [];
}

// Prev/next within this language's articles, newest first (by date).
articles.sort(
  (a, b) => new Date(b.date || '2024-01-01').getTime() - new Date(a.date || '2024-01-01').getTime()
);
const idx = articles.findIndex((a) => a.slug === slug);
const nextArticleUrl = idx > 0 ? `/${lang}/articles/${articles[idx - 1].slug}` : undefined;
const prevArticleUrl =
  idx >= 0 && idx < articles.length - 1 ? `/${lang}/articles/${articles[idx + 1].slug}` : undefined;

const langCodes = await getAvailableLanguages(env.MANIFEST);

const { title, metaDescription, keywords, structuredData, faq, audioPath, content } = data;
const direction = getLanguageDirection(lang);
const audioUrl = audioPath ? `${AUDIO_BASE}/${audioPath}` : null;

// Fix the pipeline's broken BreadcrumbList + enrich the Article schema.
const canonical = `${SITE_URL}/${lang}/articles/${slug}`;
const allStructuredData = normalizeStructuredData(structuredData, {
  lang,
  canonical,
  title,
  datePublished: data.date,
});
---

<Layout
  title={`${title} | Bible Commentary`}
  dir={direction.toUpperCase() as 'LTR' | 'RTL'}
  description={metaDescription}
  ogTitle={title}
  ogDescription={metaDescription}
  ogType="article"
  keywords={keywords}
  structuredData={allStructuredData}
  markdownHref={`${canonical}.md`}
  langCodes={langCodes}
  currentLang={lang}
  chapters={[]}
  firstChapters={firstChaptersMap}
>
  <main>
    <h1>{title}</h1>

    <FloatingControls
      prevChapter={null}
      nextChapter={null}
      audioSrc={audioUrl}
      bookSlug={null}
      lang={lang}
      prevUrl={prevArticleUrl}
      nextUrl={nextArticleUrl}
    />

    {
      /* content is authored HTML from our own trusted translation pipeline
        (stored in R2), rendered without sanitization by design. */
    }
    <article class="commentary-text">
      <Fragment set:html={content} />
    </article>

    {faq && faq.length > 0 && <FAQ items={faq} />}
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 1rem;
    padding-bottom: 8rem; /* Space for floating nav */
    width: 100%;
    max-width: 1400px;
    font-size: 20px;
    line-height: 1.6;
    color: var(--theme-text);
  }

  .commentary-text {
    margin-top: 2rem;
    font-family: var(--font-body);
  }

  /* Ensure images in markdown content are responsive */
  .commentary-text :global(img) {
    max-width: 100%;
    height: auto;
  }
</style>
