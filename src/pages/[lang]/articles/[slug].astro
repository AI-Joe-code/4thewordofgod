---
import Layout from '../../../layouts/Layout.astro';
import FloatingControls from '../../../components/FloatingControls.astro';
import FAQ from '../../../components/FAQ.astro';
import { getAllCommentary } from '../../../lib/content';
import { getLanguageDirection } from '../../../lib/languages';
import { books } from '../../../lib/books';
import { AUDIO_BASE } from '../../../lib/site';

export async function getStaticPaths() {
  const allCommentary = await getAllCommentary();

  // Filter for articles only
  const articles = allCommentary.filter((e) => e.data.type === 'article');

  // Languages present in content, for hreflang alternates.
  const languages = [...new Set(allCommentary.map((e) => e.data.language))].filter(
    (c): c is string => Boolean(c)
  );

  // Pre-calculate first chapters map for the sidebar navigation.
  const firstChaptersMap: Record<string, Record<string, string>> = {};

  for (const lang of languages) {
    const currentLangFirstChapters: Record<string, string> = {};
    books.forEach((b) => {
      const bChapters = allCommentary
        .filter(
          (e) =>
            e.data.language === lang && e.data.book?.toLowerCase().replace(/\s+/g, '-') === b.slug
        )
        .map((e) => e.data.chapter)
        .filter((c): c is string => Boolean(c))
        .sort((a, b) => parseInt(a) - parseInt(b));

      currentLangFirstChapters[b.slug] = bChapters.length > 0 ? bChapters[0] : '01';
    });
    firstChaptersMap[lang] = currentLangFirstChapters;
  }

  // Per-language article lists sorted newest-first, so prev/next is derived
  // once here instead of re-fetching all content on every page render.
  const articlesByLang: Record<string, typeof articles> = {};
  for (const lang of languages) {
    articlesByLang[lang] = articles
      .filter((e) => e.data.language === lang)
      .sort((a, b) => {
        const dateA = new Date(a.data.date || '2024-01-01');
        const dateB = new Date(b.data.date || '2024-01-01');
        return dateB.getTime() - dateA.getTime(); // Descending (Newest first)
      });
  }

  return articles.map((entry) => {
    // entry.slug is like "en/articles/fall-of-the-world-trade-center"
    const [lang, _, slug] = entry.slug.split('/');

    const sorted = articlesByLang[lang] ?? [];
    const i = sorted.findIndex((e) => e.slug === entry.slug);
    // List is newest-first: newer article is i-1, older is i+1.
    const nextArticleUrl = i > 0 ? `/${sorted[i - 1].slug}` : undefined;
    const prevArticleUrl = i >= 0 && i < sorted.length - 1 ? `/${sorted[i + 1].slug}` : undefined;

    return {
      params: { lang, slug },
      props: {
        entry,
        langCodes: languages,
        firstChaptersMap: firstChaptersMap[lang],
        prevArticleUrl,
        nextArticleUrl,
      },
    };
  });
}

const { entry, langCodes, firstChaptersMap, prevArticleUrl, nextArticleUrl } = Astro.props;

const { title, metaDescription, keywords, structuredData, faq, audioPath, content } = entry.data;

const lang = entry.data.language ?? 'en';
const direction = getLanguageDirection(lang);

const audioUrl = audioPath ? `${AUDIO_BASE}/${audioPath}` : null;
---

<Layout
  title={`${title} | Bible Commentary`}
  dir={direction.toUpperCase() as 'LTR' | 'RTL'}
  description={metaDescription}
  ogTitle={title}
  ogDescription={metaDescription}
  ogType="article"
  keywords={keywords}
  structuredData={structuredData}
  langCodes={langCodes}
  currentLang={lang}
  chapters={[]}
  firstChapters={firstChaptersMap}
>
  <main>
    <h1>{title}</h1>

    <FloatingControls
      prevChapter={null}
      nextChapter={null}
      audioSrc={audioUrl}
      bookSlug={null}
      lang={lang}
      prevUrl={prevArticleUrl}
      nextUrl={nextArticleUrl}
    />

    {
      /* content is authored HTML from our own trusted translation pipeline
        (build-time content source), rendered without sanitization by design. */
    }
    <article class="commentary-text">
      <Fragment set:html={content} />
    </article>

    {faq && faq.length > 0 && <FAQ items={faq} />}
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 1rem;
    padding-bottom: 8rem; /* Space for floating nav */
    width: 100%;
    max-width: 1400px;
    font-size: 20px;
    line-height: 1.6;
    color: var(--theme-text);
  }

  .commentary-text {
    margin-top: 2rem;
    font-family: var(--font-body);
  }

  /* Ensure images in markdown content are responsive */
  .commentary-text :global(img) {
    max-width: 100%;
    height: auto;
  }
</style>
