---
// Rendered on-demand by the Cloudflare adapter (Worker), reading chapter
// content from R2 instead of the build-time filesystem. This is the route
// that lets the site scale to hundreds of languages without hitting
// per-deployment static-file limits on Cloudflare's free tier.
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import FloatingControls from '../../../components/FloatingControls.astro';
import FAQ from '../../../components/FAQ.astro';
import { getLanguageDirection, getAvailableLanguages } from '../../../lib/languages';
import type { CommentaryData } from '../../../lib/content';
import { AUDIO_BASE } from '../../../lib/site';
import { env } from 'cloudflare:workers';

const { lang, book, chapter } = Astro.params;
if (!lang || !book || !chapter) {
  return Astro.rewrite('/404');
}

if (!env.R2) {
  return new Response('R2 binding unavailable', { status: 500 });
}

// 1. Fetch this chapter's content.
const key = `public-content/${lang}/json/${book}_${chapter}.json`;
const obj = await env.R2.get(key);
if (!obj) {
  return Astro.rewrite('/404');
}
const data = (await obj.json()) as CommentaryData;

// 2. Navigation comes from the per-language manifest in KV (one small read,
//    with real chapter titles). Falls back to an R2 listing if the manifest
//    has not been generated yet.
let bookChapters: { chapter_number: string; original_title: string | null }[];
const firstChaptersMap: Record<string, string> = {};

const manifestRaw = await env.MANIFEST?.get(`manifest:${lang}`);
if (manifestRaw) {
  const manifest = JSON.parse(manifestRaw) as {
    books: Record<string, { name?: string; chapters: { n: string; title: string }[] }>;
  };
  for (const bk in manifest.books) {
    firstChaptersMap[bk] = manifest.books[bk].chapters[0]?.n ?? '01';
  }
  bookChapters = (manifest.books[book!]?.chapters ?? []).map((c) => ({
    chapter_number: c.n,
    original_title: c.title || null,
  }));
} else {
  const listed = await env.R2.list({ prefix: `public-content/${lang}/json/` });
  const chaptersByBook: Record<string, string[]> = {};
  for (const o of listed.objects) {
    const m = o.key.match(/\/json\/(.+)_(\d+)\.json$/);
    if (!m) continue;
    const [, bk, ch] = m;
    (chaptersByBook[bk] ??= []).push(ch);
  }
  for (const bk in chaptersByBook) {
    chaptersByBook[bk].sort((a, b) => parseInt(a, 10) - parseInt(b, 10));
    firstChaptersMap[bk] = chaptersByBook[bk][0] ?? '01';
  }
  bookChapters = (chaptersByBook[book!] ?? []).map((num) => ({
    chapter_number: num,
    original_title: null,
  }));
}

// 3. Prev/next derived from the ordered chapter list (robust to stale JSON).
const idx = bookChapters.findIndex((c) => c.chapter_number === chapter);
const prevChapterNum = idx > 0 ? bookChapters[idx - 1].chapter_number : null;
const nextChapterNum =
  idx >= 0 && idx < bookChapters.length - 1 ? bookChapters[idx + 1].chapter_number : null;

// Languages this URL exists in, for hreflang alternates (sourced from the
// global manifest, falling back to the statically-known set).
const langCodes = await getAvailableLanguages(env.MANIFEST);

const { title, metaDescription, keywords, structuredData, faq, audioPath, content } = data;

const direction = getLanguageDirection(lang!);
const audioUrl = audioPath ? `${AUDIO_BASE}/${audioPath}` : null;
---

<Layout
  title={`${title} | Bible Commentary`}
  dir={direction.toUpperCase() as 'LTR' | 'RTL'}
  description={metaDescription}
  ogTitle={title}
  ogDescription={metaDescription}
  ogType="article"
  keywords={keywords}
  structuredData={structuredData}
  langCodes={langCodes}
  currentLang={lang}
  chapters={bookChapters}
  currentBook={book}
  currentChapter={chapter}
  firstChapters={firstChaptersMap}
>
  <main>

    <h1>{title}</h1>

    <FloatingControls
      prevChapter={prevChapterNum}
      nextChapter={nextChapterNum}
      audioSrc={audioUrl}
      bookSlug={book}
      lang={lang}
    />

    {/* content is authored HTML from our own trusted translation pipeline
        (stored in R2), so it is intentionally rendered without sanitization. */}
    <article class="commentary-text">
      <Fragment set:html={content} />
    </article>

    {faq && faq.length > 0 && (
      <FAQ items={faq} />
    )}
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 1rem;
    padding-bottom: 8rem; /* Space for floating nav */
    width: 100%;
    max-width: 1400px;
    font-size: 20px;
    line-height: 1.6;
    color: var(--theme-text);
  }

  .commentary-text {
    margin-top: 2rem;
    font-family: 'Lato', sans-serif;
  }

  /* Ensure images in markdown content are responsive */
  .commentary-text :global(img) {
    max-width: 100%;
    height: auto;
  }
</style>
